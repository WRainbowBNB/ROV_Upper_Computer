     <widget class="QSlider" name="temperature_slider">
      <property name="styleSheet">
       <string notr="true">/* 1. 滑动槽（底部的灰色轨道） */
QSlider::groove:vertical {
    background: #e0e0e0;
    width: 24px; /* 这里决定了滑杆有多粗！你可以改大改小 */
    border-radius: 12px; /* 圆角，通常是宽度的一半 */
}

/* 2. 已滑过的区域（代表当前数值的颜色带，比如变成显眼的绿色） */
QSlider::sub-page:vertical {
    background: #00B050; /* 咱们之前选的标准绿色 */
    width: 24px;
    border-radius: 12px;
}

/* 3. 滑块手柄（你用鼠标拖动的那个小方块） */
QSlider::handle:vertical {
    height: 30px; /* 手柄的高度 */
    margin: 0px -4px; /* 让手柄往两边稍微凸出去一点，更好看 */
    background: white;
    border: 2px solid #00B050;
    border-radius: 15px;
}</string>
      </property>
      <property name="orientation">
       <enum>Qt::Vertical</enum>
      </property>
